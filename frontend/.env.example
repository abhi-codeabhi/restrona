# Base URLs of the deployed BFFs (Render). One per surface.
VITE_CUSTOMER_API=https://restorna-customer.onrender.com
VITE_WAITER_API=https://restorna-waiter.onrender.com
VITE_KITCHEN_API=https://restorna-kitchen.onrender.com
VITE_BILLING_API=https://restorna-billing.onrender.com
VITE_OWNER_API=https://restorna-owner.onrender.com

# Tenant the app operates as when NOT logged in (anonymous QR / dev). When a user
# logs in, the resolved tenant from their profile overrides this.
VITE_TENANT_ID=acme

# Supabase Auth (OTP login). Leave BOTH blank to disable login (app stays open).
# Set them to turn on per-persona OTP sign-in. Find these in Supabase → Project
# Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
