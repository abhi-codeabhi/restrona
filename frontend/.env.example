# The ONE unified API every surface talks to (shared store + order-flow saga).
# Point this at your restorna-api service on Render.
VITE_API_URL=https://restorna-api.onrender.com

# Optional: override individual surfaces if you ever split the backend again.
# Leave unset to use VITE_API_URL for all of them.
# VITE_CUSTOMER_API=
# VITE_WAITER_API=
# VITE_KITCHEN_API=
# VITE_BILLING_API=
# VITE_OWNER_API=

# Tenant the app operates as when NOT logged in (anonymous QR / dev). When a user
# logs in, the resolved tenant from their profile overrides this. For the in-memory
# demo API this is `acme`; for Supabase-backed it's your tenant UUID.
VITE_TENANT_ID=acme

# Supabase Auth (OTP login). Leave BOTH blank to disable login (app stays open).
# Set them to turn on per-persona OTP sign-in. Find these in Supabase → Project
# Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
