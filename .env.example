# Restorna — example environment. Copy to `.env` and fill in real values.
# NOT-YET-VERIFIED: the Postgres slice has not been run against a live database
# in this environment. See SUPABASE.md.

# --- Supabase / Postgres ---------------------------------------------------

# DATABASE_URL — Supabase TRANSACTION-mode pooler (Supavisor), port 6543.
# Use this for the running app / serverless functions: it multiplexes many
# short-lived clients onto few Postgres backends.
# IMPORTANT: transaction pooling does NOT support session-level features.
# Disable prepared statements on this connection — node-postgres uses the
# simple query protocol by default (no prepared statements), but if you enable
# them, append `?pgbouncer=true` / `?prepared_statements=false` (driver-
# dependent) or you will get "prepared statement already exists" errors.
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# DIRECT_URL — direct connection, port 5432 (session mode). Use for running
# migrations and any operation that needs prepared statements / session state.
DIRECT_URL=postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- App -------------------------------------------------------------------
PORT=3001
